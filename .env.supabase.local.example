# Copy this file to .env.supabase.local when a Supabase CLI command needs
# environment-based auth or connection settings.
#
# Keep every value on a single line. Do not paste PEM blocks or other multiline
# secrets here. The wrapper script temporarily swaps this file in as .env while
# the Supabase CLI runs.
#
# Example values:
# SUPABASE_ACCESS_TOKEN=your-access-token
# SUPABASE_DB_PASSWORD=your-database-password
# PGPASSWORD=your-database-password
