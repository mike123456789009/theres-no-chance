{
  "name": "theres-no-chance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "verify:public-barrels": "tsc --noEmit -p tsconfig.public-barrels.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run lint && npm run verify:public-barrels && npm run typecheck && npm test && npm run build",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "supabase": "bash ./scripts/supabase-safe.sh",
    "supabase:link": "bash ./scripts/supabase-safe.sh link --project-ref ynuyfchtajpmnbcpbagb",
    "supabase:migration:list": "bash ./scripts/supabase-safe.sh migration list",
    "supabase:db:push": "bash ./scripts/supabase-safe.sh db push --linked --yes",
    "market:scan:public": "tsx scripts/market-research-runner.ts --scope=public --submit --max=20",
    "market:scan:institution": "tsx scripts/market-research-runner.ts --scope=institution --submit --max=10",
    "market:scan:public:dry": "tsx scripts/market-research-runner.ts --scope=public --dry-run --max=20",
    "market:scan:institution:dry": "tsx scripts/market-research-runner.ts --scope=institution --dry-run --max=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike123456789009/theres-no-chance.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mike123456789009/theres-no-chance/issues"
  },
  "homepage": "https://github.com/mike123456789009/theres-no-chance#readme",
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
