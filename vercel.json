{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/automation/market-research/public",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/automation/market-research/institution",
      "schedule": "30 */12 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.theres-no-chance.com"
        }
      ],
      "destination": "https://theres-no-chance.com/$1",
      "permanent": true
    }
  ]
}
